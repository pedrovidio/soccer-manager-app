{
  "expo": {
    "name": "Não Fico Sem Jogar",
    "slug": "soccer-manager-app",
    "scheme": "soccer-manager",
    "version": "1.0.0",
    "icon": "./assets/logo.png",
    "updates": {
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usamos sua localizacao para encontrar vagas avulsas perto de voce."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#0A0F1E",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.anonymous.soccermanagerapp",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "androidNavigationBar": {
      "barStyle": "dark-content"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f351a9c0-3275-43ed-82f5-5b5880fc07df"
      }
    },
    "owner": "pedrovidio"
  }
}
